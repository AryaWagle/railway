# Open Supply Hub — generate at https://opensupplyhub.org/ (My Account → Settings → API)
# Copy this file to `.env.local` and paste your trial token (never commit `.env.local`).
OSH_API_TOKEN=

# Optional override (default: https://opensupplyhub.org/api)
# OSH_BASE_URL=https://staging.opensupplyhub.org/api

# Live aggregation (when OSH_API_TOKEN is set): page size, max pages, hard cap on features
# OSH_PAGE_SIZE=100
# OSH_MAX_PAGES=25
# OSH_FEATURE_CAP=5000

# Optional: protect POST /api/sync/osh when you add background sync
# SYNC_CRON_SECRET=
